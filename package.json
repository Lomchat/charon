{
  "name": "charon",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted web hub for orchestrating Claude Code / Claude Agent SDK sessions across multiple VPS over SSH.",
  "license": "Apache-2.0",
  "author": "Lomchat",
  "homepage": "https://github.com/Lomchat/charon#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lomchat/charon.git"
  },
  "bugs": {
    "url": "https://github.com/Lomchat/charon/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claude-agent-sdk",
    "anthropic",
    "ssh",
    "vps",
    "nextjs",
    "self-hosted",
    "agent",
    "dashboard"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node server.js",
    "build": "node scripts/check-protocol-sync.mjs && next build",
    "start": "node server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:py": "python3 -m unittest discover -s agent/tests -v",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node ./scripts/migrate.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^11.8.1",
    "diff": "^9.0.0",
    "drizzle-orm": "^0.45.2",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "web-push": "^3.6.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.10.6",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.3",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
