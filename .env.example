DATABASE_URL=./data/charon.db
SESSION_SECRET=<openssl rand -hex 32>
HOST=127.0.0.1
PORT=10556
NODE_ENV=production
MASTER_PASSWORD='votre mot de passe'
MASTER_SALT=<openssl rand -hex 32>
# Subject (mailto: ou https://) injecté dans les push Web. Identité de
# l'expéditeur, vu par les serveurs push. Pas critique mais à personnaliser.
VAPID_SUBJECT=mailto:admin@example.com
# Token Bearer pour l'endpoint /api/sync (push de VPS depuis un hub externe).
SYNC_TOKEN=<openssl rand -hex 32>
