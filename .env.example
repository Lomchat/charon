# ----------------------------------------------------------------------------
# Charon configuration. Copy to `.env` and fill in.
#
# Generate the three random secrets with:
#   openssl rand -hex 32
# (run it once per variable — they must be independent).
#
# DO NOT commit your real .env. The .gitignore excludes it.
# ----------------------------------------------------------------------------

# Login password for the dashboard AND seed for the AES key that encrypts
# sensitive settings in SQLite. Changing this after first boot will lock
# you out of any encrypted setting (currently: the web-push private key).
# Choose a strong passphrase and store it in a password manager.
MASTER_PASSWORD='your master password here'

# scrypt salt for deriving the AES key from MASTER_PASSWORD. Generate with
# `openssl rand -hex 32`. Treat as a secret.
MASTER_SALT=<openssl rand -hex 32>

# Signs session cookies. Generate with `openssl rand -hex 32`.
SESSION_SECRET=<openssl rand -hex 32>

# Bearer token gating POST /api/sync (used to ingest VPS+paths from an
# external source). Generate with `openssl rand -hex 32`.
SYNC_TOKEN=<openssl rand -hex 32>

# Path to the SQLite database. The migrations directory is `./drizzle`.
# In Docker, point this at /app/data/charon.db (matches the volume mount).
DATABASE_URL=./data/charon.db

# Bind host and port for `next start`. Defaults match the production
# topology (loopback only, behind a reverse proxy that terminates TLS).
HOST=127.0.0.1
PORT=10556

# Must be `production` to enable HSTS + Secure cookies. Leave as is unless
# you know what you're doing.
NODE_ENV=production

# Web Push subject — identifies the sender to push notification servers.
# Override-able from the in-app Settings panel. Accepts mailto: or https://.
VAPID_SUBJECT=mailto:admin@example.com
